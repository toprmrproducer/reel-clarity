---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Page Not Found — ReelClarity"
	description="This page doesn't exist. Return to ReelClarity to enhance your video's resolution and sharpness on-device."
	canonicalPath="/404"
>
	<section class="mx-auto max-w-xl text-center">
		<p class="text-sm font-semibold uppercase tracking-widest text-[#C9982E]">404</p>
		<h1 class="mt-3 text-3xl font-semibold tracking-tight text-[#2B2013] sm:text-4xl">
			Page not found
		</h1>
		<p class="mt-4 text-[#5C4F3D]">
			The page you're looking for doesn't exist or may have moved.
		</p>
		<a
			href={import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`}
			class="mt-8 inline-flex items-center gap-2 rounded-xl bg-[#C9982E] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#B8860B]"
		>
			Back to ReelClarity
		</a>
	</section>
</Layout>
