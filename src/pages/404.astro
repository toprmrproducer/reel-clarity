---
import Layout from '../layouts/Layout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<Layout
	title="Page Not Found — ReelClarity"
	description="This page doesn't exist. Return to ReelClarity to enhance your video's resolution and sharpness on-device."
	canonicalPath="/404"
>
	<section class="mx-auto max-w-[560px] text-center">
		<p class="text-sm font-bold uppercase tracking-[0.2em] text-[#c9982e]">404</p>
		<h1 class="mt-4 text-4xl font-extrabold tracking-tight text-[#221b10] sm:text-[2.75rem]">
			Page not found
		</h1>
		<p class="mt-4 text-lg text-[#4a4234]">
			The page you're looking for doesn't exist or may have moved.
		</p>
		<a
			href={base}
			class="mt-8 inline-flex items-center gap-2 rounded-xl bg-[#c9982e] px-6 py-3.5 text-[15px] font-semibold text-white shadow-sm transition hover:bg-[#b8860b]"
		>
			Back to ReelClarity
		</a>
	</section>
</Layout>
