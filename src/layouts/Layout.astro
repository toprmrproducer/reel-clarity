---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonicalPath?: string;
}

const { title, description, canonicalPath = '/' } = Astro.props;
const siteUrl = 'https://toprmrproducer.github.io';
// Astro's BASE_URL does not guarantee a trailing slash (e.g. "/reel-clarity"),
// so normalize it to always end in "/" before concatenating path segments.
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
// canonicalPath is passed as a site-root-relative path like "/" or "/about";
// prepend the base path so canonical/OG URLs resolve to the deployed subpath.
const fullPath = `${base}${canonicalPath.replace(/^\//, '')}`;
const canonical = new URL(fullPath, siteUrl).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body class="min-h-screen bg-[#ffffff] text-[#4a4234] antialiased">
		<!-- Header -->
		<header class="border-b border-[#eae4d6] bg-white/90 backdrop-blur">
			<nav class="mx-auto flex max-w-[820px] items-center justify-between px-6 py-5">
				<a href={base} class="font-[Sora] text-xl font-extrabold tracking-tight text-[#221b10]">
					Reel<span class="text-[#c9982e]">Clarity</span>
				</a>
				<a
					href={`${base}#tool`}
					class="rounded-full bg-[#c9982e] px-5 py-2.5 text-[15px] font-semibold text-white shadow-sm transition hover:bg-[#b8860b]"
				>
					Open the tool
				</a>
			</nav>
		</header>

		<!-- AdSense: top leaderboard slot (reserved, invisible until a real <ins> is dropped in) -->
		<div class="mx-auto max-w-[820px] px-6">
			<div class="ad-slot ad-leaderboard mx-auto" data-ad-slot="leaderboard" style="max-width:970px;min-height:0">
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</div>
		</div>

		<!--
			Page shell: a flex row that keeps <main> hard-capped at 820px and
			centered, with two sticky skyscraper ad gutters that only appear at
			>=1280px so they sit in the genuinely empty left/right space.
		-->
		<div class="mx-auto flex w-full max-w-[1400px] items-start justify-center gap-8 px-4">
			<!-- AdSense: left skyscraper (hidden below xl, sticky in the gutter) -->
			<aside
				class="ad-slot ad-skyscraper sticky top-[120px] hidden w-[160px] shrink-0 xl:block"
				data-ad-slot="skyscraper-left"
				style="min-height:0"
			>
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</aside>

			<main class="mx-auto w-full max-w-[820px] px-6 pt-24 pb-28">
				<slot />
			</main>

			<!-- AdSense: right skyscraper (hidden below xl, sticky in the gutter) -->
			<aside
				class="ad-slot ad-skyscraper sticky top-[120px] hidden w-[160px] shrink-0 xl:block"
				data-ad-slot="skyscraper-right"
				style="min-height:0"
			>
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</aside>
		</div>

		<!-- AdSense: bottom in-article slot (reserved, invisible until filled) -->
		<div class="mx-auto max-w-[820px] px-6">
			<div class="ad-slot ad-in-article mx-auto" data-ad-slot="in-article" style="max-width:728px;min-height:0">
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</div>
		</div>

		<!-- Footer -->
		<footer class="mt-24 border-t border-[#eae4d6] bg-[#faf8f3]">
			<div class="mx-auto max-w-[820px] px-6 py-12 text-[15px] text-[#4a4234]">
				<p class="max-w-xl leading-relaxed">
					Every enhancement runs locally in your browser. Nothing you upload is
					ever sent to a server.
				</p>
				<div class="mt-5 flex flex-wrap gap-6 font-medium">
					<a href={`${base}about`} class="transition hover:text-[#b8860b]">About</a>
					<a href={`${base}privacy`} class="transition hover:text-[#b8860b]">Privacy Policy</a>
					<a href={`${base}faq`} class="transition hover:text-[#b8860b]">FAQ</a>
				</div>
				<p class="mt-6 text-[#8a7e68]">&copy; {new Date().getFullYear()} ReelClarity &middot; built by RapidXAI</p>
			</div>
		</footer>

		<style is:global>
			/*
				Reserved AdSense slots. They occupy their spot in the flow / gutter
				but render NOTHING visible until a real ad unit is inserted, so an
				empty placeholder never shows a dashed "Advertisement" box (which can
				hurt AdSense approval). Once an <ins> is added the slot grows to fit.
			*/
			.ad-slot:empty {
				min-height: 0;
				height: 0;
				margin: 0;
				border: 0;
				background: none;
			}
			.ad-leaderboard,
			.ad-in-article {
				width: 100%;
			}
		</style>
	</body>
</html>
